# Server-side Supabase (used by createServerFn handlers and SSR)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Client-side Supabase (exposed to the browser by Vite at build time)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Canonical public site URL used for auth email redirects (must match Supabase Auth "Site URL" + "Redirect URLs")
VITE_SITE_URL="https://focus-flow-ai-final.vercel.app"

# Lovable AI Gateway (used by AI features: coach, insights, story, dna, growth)
LOVABLE_API_KEY="your-lovable-ai-gateway-key"
